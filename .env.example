# Port the panel listens on
PANEL_PORT=4000

# Where per-user login accounts are stored (hashed PINs, created via
# `node scripts/add-user.mjs <username> <pin>`). Not committed to git.
USERS_PATH=./users.json

# The Master Hive node (orbitfs-mcp-server). Usually http://localhost:PORT if
# this panel runs on the same machine as the Hive server.
HIVE_URL=http://localhost:3939
HIVE_API_KEY=same-as-HIVE_API_KEY-in-orbitfs-mcp-server/.env

# Host-specific Windows paths used by the System tab's service/process
# controls and log viewers. Leave these at the defaults if your layout
# matches the original VPS.
PANEL_SERVICE_NAME=OrbitFSPanel
HIVE_SERVICE_NAME=OrbitFSMcpServer
HIVE_SERVER_DIR=F:\orbitfs-mcp-server
HIVE_LOG_DIR=F:\orbitfs-mcp-server\logs
CLOUDFLARED_SERVICE_NAME=OrbitFSTunnel
CLOUDFLARED_DIR=C:\cloudflared
# Optional explicit locations if you don't use the defaults above.
# CLOUDFLARED_EXE=C:\cloudflared\cloudflared.exe
# CLOUDFLARED_CONFIG=C:\Users\Lucas\.cloudflared\config.yml
# CLOUDFLARED_TUNNEL_NAME=master-hive
# PANEL_POWERSHELL_PATH=C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe
# PANEL_SYSTEM_DRIVE=C

# Password required (in addition to being an admin, and typing the exact
# confirm phrase in the UI) before the System tab's "hard stop" button will
# run. That button shuts down the whole machine (Stop-Computer -Force) via
# PANEL_HARDSTOP_SCRIPT_PATH below, so treat this like a real credential.
# Leave blank to disable the hard-stop button entirely.
PANEL_HARDSTOP_PASSWORD=

# Path to the PowerShell script the hard-stop button runs. Not part of this
# repo - create it yourself (typically just `Stop-Computer -ComputerName
# localhost -Force`) and point this at it. Leave unset only if you're fine
# with the Windows default below, which won't exist on a fresh machine.
# PANEL_HARDSTOP_SCRIPT_PATH=C:\Users\Lucas\Desktop\hardstop.ps1

# --- Optional: addon sorter plugin ---
# orbitfs-sorter is a separate, optional tool (not part of this repo) -
# classifies _sorter items against the live folder tree and lets you edit
# the destination before confirming, no AI key needed. The Sort button and
# Sorter service controls automatically hide themselves if SORTER_DIR
# doesn't exist on disk, so there's nothing to configure if you're not
# using it. Set SORTER_ENABLED=false to hide it even if it's installed.
# SORTER_DIR=F:\orbitfs-mcp-server\orbitfs-sorter
# SORTER_URL=http://localhost:4055
# SORTER_SERVICE_NAME=OrbitFSSorter
# SORTER_ENABLED=false

