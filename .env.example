PANEL_PORT=
HIVE_URL=
HIVE_API_KEY=
HIVE_SERVER_DIR=
HIVE_LOG_DIR=
HIVE_SERVICE_NAME=
PANEL_SERVICE_NAME=
CLOUDFLARED_SERVICE_NAME=
CLOUDFLARED_DIR=
SORTER_SERVICE_NAME=
SORTER_DIR=
SORTER_URL=
# Cloudflare Access automation for MCP member links (workspace_mcp_grants).
# CF_ACCESS_APP_ID is the Access Application fronting the MCP server, not the panel.
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ACCESS_APP_ID=
MCP_PUBLIC_URL=
# Shared secret orbitfs-mcp sends as X-Internal-Key to /internal/mcp-identity.
# Must match the same value in orbitfs-mcp's .env (see its README).
MCP_INTERNAL_KEY=

ORBITFS_LICENSE_API_URL=
ORBITFS_LICENSE_VALIDATE_PATH=/api/license/validate
ORBITFS_LICENSE_DIR=C:\ProgramData\OrbitFS
ORBITFS_LICENSE_REFRESH_MINUTES=180
ORBITFS_LICENSE_GRACE_HOURS=72
ORBITFS_LICENSE_TIMEOUT_MS=8000ORBITFS_LICENSE_SIGNAL_MINUTES=1

ORBITFS_BUILD_CHANNEL=production
ORBITFS_ENTITLEMENT_PUBLIC_KEY_PATH=./entitlement-public.pem
