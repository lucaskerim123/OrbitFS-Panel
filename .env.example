# Port the panel listens on
PANEL_PORT=4000

# Where per-user login accounts are stored (hashed PINs, created via
# `node scripts/add-user.mjs <username> <pin>`). Not committed to git.
USERS_PATH=./users.json

# The OrbitFS MCP node (orbitfs-mcp). Usually http://localhost:PORT if
# this panel runs on the same machine as the MCP server.
HIVE_URL=http://localhost:3939
HIVE_API_KEY=same-as-HIVE_API_KEY-in-orbitfs-mcp/.env

# Paths used by the System tab's service/process controls and log viewers.
# Install-OrbitFS.ps1 / Setup-Services.ps1 fill these in for you based on
# wherever you chose to install - only edit by hand if your layout diverges
# from what those scripts set up.
PANEL_SERVICE_NAME=OrbitFSPanel
HIVE_SERVICE_NAME=OrbitFSMcpServer
HIVE_SERVER_DIR=F:\orbitfs-mcp
HIVE_LOG_DIR=F:\orbitfs-mcp\logs
SORTER_DIR=F:\orbitfs-mcp\hive-addon-sorter
SORTER_URL=http://localhost:4055
SORTER_SERVICE_NAME=OrbitFSSorter
CLOUDFLARED_SERVICE_NAME=OrbitFSTunnel
CLOUDFLARED_DIR=C:\cloudflared
# Optional explicit overrides if the above defaults don't match your setup.
# CLOUDFLARED_EXE=C:\cloudflared\cloudflared.exe
# CLOUDFLARED_CONFIG=<your user profile>\.cloudflared\config.yml
# CLOUDFLARED_TUNNEL_NAME=master-hive
# PANEL_POWERSHELL_PATH=C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe
# PANEL_SYSTEM_DRIVE=C
# SORTER_ENABLED=false

# Password required (in addition to being an admin, and typing the exact
# confirm phrase in the UI) before the System tab's "hard stop" button will
# run. That button shuts down the whole machine (Stop-Computer -Force) via
# PANEL_HARDSTOP_SCRIPT_PATH below, so treat this like a real credential.
# Leave blank to disable the hard-stop button entirely.
PANEL_HARDSTOP_PASSWORD=

# Path to the PowerShell script the hard-stop button runs. Not part of this
# repo - create it yourself (typically just `Stop-Computer -ComputerName
# localhost -Force`) and point this at it. Leave unset to disable.
# PANEL_HARDSTOP_SCRIPT_PATH=<path to your own hardstop.ps1>
