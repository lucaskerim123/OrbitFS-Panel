# Port the panel listens on
PANEL_PORT=4000

# Bearer key required to log into the panel and call its API
PANEL_API_KEY=change-me

# The PC-hosted Master Hive node (mcp-hive-server), reached over its Cloudflare tunnel
NODE_PC_URL=https://your-tunnel-domain.example.com
NODE_PC_API_KEY=same-as-HIVE_API_KEY-on-the-pc

# The VPS-hosted Master Hive node (a second mcp-hive-server instance running on this VPS)
NODE_VPS_URL=http://localhost:3939
NODE_VPS_API_KEY=same-as-HIVE_API_KEY-on-the-vps
